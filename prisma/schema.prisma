generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Role {
  id    Int     @id @default(autoincrement())
  admin Boolean @default(false)
  name  String  @unique
  users User[]
}

model RootsType {
  id              Int               @id @default(autoincrement())
  name            String            @unique
  description     String?
  rootsTypesSteps RootsTypesSteps[]
  users           User[]
  processHistoryList ProcessHistory[]
}


model User {
  id                    String                @id @default(uuid())
  name                  String
  lastname              String?
  password              String?
  email                 String                @unique
  whatsappId            String?
  roleId                Int?
  rootsTypeId           Int?
  emailVerified         DateTime?
  image                 String?
  accounts              Account[]
  sessions              Session[]
  role                  Role?                 @relation(fields: [roleId], references: [id])
  rootsType             RootsType?            @relation(fields: [rootsTypeId], references: [id])
  progressList          UserProcessProgress[] @relation("UserProgress")
  validatedProgressList UserProcessProgress[] @relation("AdminValidation")
  
  // Nuevos campos para la gestión de datos de clientes
  driveFolderUrl        String?
  passportUrl           String?
  passportStatus        String                @default("Pending")
  appointmentDate       DateTime?
  registrationMonth     String?
  consentGiven          Boolean               @default(false)
  lastDocumentValidationAt DateTime?

  // Relaciones para AuditLog
  performedActions      AuditLog[]            @relation("PerformedActions")
  clientAuditLogs       AuditLog[]            @relation("ClientAuditLogs")
  processHistoryList    ProcessHistory[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Step {
  id              Int                   @id @default(autoincrement())
  name            String
  description     String?
  triggerCondition String?
  geminiInstructions String?
  rootsTypesSteps RootsTypesSteps[]
  progress        UserProcessProgress[]
  processHistoryList ProcessHistory[]
  stageId         Int?
  stage           KanbanStage?          @relation(fields: [stageId], references: [id], onDelete: SetNull)
}

model KanbanStage {
  id          Int      @id @default(autoincrement())
  name        String
  order       Int      @default(1)
  description String?
  steps       Step[]
}


model RootsTypesSteps {
  id          Int       @id @default(autoincrement())
  rootsTypeId Int
  stepId      Int
  isMandatory Boolean   @default(false)
  shortOrder  Int       @default(1)
  rootsType   RootsType @relation(fields: [rootsTypeId], references: [id])
  step        Step      @relation(fields: [stepId], references: [id])

  @@unique([rootsTypeId, stepId])
}

model Document {
  id        Int                   @id @default(autoincrement())
  extension String
  url       String
  name      String
  progress  UserProcessProgress[]
}

model UserProcessProgress {
  id                Int       @id @default(autoincrement())
  userId            String
  stepId            Int
  documentId        Int?
  status            String    @default("Pending")
  value             String?
  adminComments     String?
  validatedByUserId String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  document          Document? @relation(fields: [documentId], references: [id])
  step              Step      @relation(fields: [stepId], references: [id])
  user              User      @relation("UserProgress", fields: [userId], references: [id])
  validatedByUser   User?     @relation("AdminValidation", fields: [validatedByUserId], references: [id])
}

model StatusConfig {
  id        String   @id // e.g. "Pending", "Uploaded", "Approved", "Rejected" or custom ones
  label     String   // e.g. "Pendiente", "Subido", "Aprobado", "Rechazado"
  color     String   // Background color code, e.g. "#f3f4f6"
  textColor String   // Text color code, e.g. "#1f2937"
}

model AuditLog {
  id                String   @id @default(uuid())
  action            String   // ej. "UPDATE_STEP_STATUS", "UPLOAD_PASSPORT", "UPDATE_CLIENT_DETAILS", "ASSIGN_ROOTS_TYPE"
  entityType        String   // ej. "UserProcessProgress", "User"
  entityId          String   // ID de la entidad afectada
  performedByUserId String?  // ID del administrador que realizó la acción
  clientUserId      String?  // ID del cliente asociado al cambio
  oldValues         String?  // JSON string con los valores anteriores
  newValues         String?  // JSON string con los nuevos valores
  createdAt         DateTime @default(now())

  performedByUser   User?    @relation("PerformedActions", fields: [performedByUserId], references: [id])
  clientUser        User?    @relation("ClientAuditLogs", fields: [clientUserId], references: [id])
}

model WhatsAppMessage {
  id         String   @id @default(uuid())
  whatsappId String
  direction  String   // "INCOMING" | "OUTGOING"
  type       String   // "text" | "image"
  content    String   // Text content or media URL / media ID
  createdAt  DateTime @default(now())

  @@index([whatsappId])
}

model ProcessHistory {
  id          String   @id @default(uuid())
  userId      String
  rootsTypeId Int
  stepId      Int?     // Paso específico si aplica
  status      String   // El estado del proceso o paso
  comments    String?  // Observaciones de la transición
  createdAt   DateTime @default(now())

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  rootsType RootsType @relation(fields: [rootsTypeId], references: [id], onDelete: Cascade)
  step      Step?     @relation(fields: [stepId], references: [id], onDelete: SetNull)
}

